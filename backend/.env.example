# ============================================================
# Raidex Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# MongoDB (current runtime)
MONGO_URL=mongodb://localhost:27017
DB_NAME=raidex

# Supabase (migration target — use connection pooler for serverless)
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string
ENV=development
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Admin (set before first deploy to avoid random password in logs)
# ADMIN_EMAIL=admin@raidex.io
# ADMIN_PASSWORD=your-strong-admin-password

# ── Payment Gateway ──────────────────────────────────────────
# Options: mock | razorpay
PAYMENT_PROVIDER=mock

# Razorpay (set PAYMENT_PROVIDER=razorpay to activate)
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* for testing, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── KYC Provider ─────────────────────────────────────────────
# Options: stub | karza | idfy
KYC_PROVIDER=stub

# Karza (set KYC_PROVIDER=karza to activate)
# Register at: https://karza.in
# Test: https://testapi.karza.in | Production: https://api.karza.in
KARZA_API_KEY=your_karza_api_key
KARZA_BASE_URL=https://testapi.karza.in

# IDfy (set KYC_PROVIDER=idfy to activate)
# Register at: https://app.idfy.io
IDFY_ACCOUNT_ID=your_idfy_account_id
IDFY_API_KEY=your_idfy_api_key
IDFY_BASE_URL=https://api.idfy.io

# ── Push Notifications ───────────────────────────────────────
# Options: log | expo | onesignal
PUSH_PROVIDER=log

# OneSignal (set PUSH_PROVIDER=onesignal to activate)
# Register at: https://onesignal.com
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# Expo Push — no server-side key needed (uses expo's push service)
# Set PUSH_PROVIDER=expo and ensure frontend registers tokens via /push/register

# ── AI / LLM ─────────────────────────────────────────────────
# Required for Support/Ops/Finance agents + owner anomaly cron
EMERGENT_LLM_KEY=your_emergent_llm_api_key

# ── Damage AI Inspector ──────────────────────────────────────
# Options: stub
DAMAGE_AI_PROVIDER=stub

# Monitoring / alerting
# Configure alert routing inside Sentry or your monitoring provider dashboard.
# Do not send personal email directly from application code.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ALERT_WEBHOOK_URL=
RAIDEX_GSTIN=
