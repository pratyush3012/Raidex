# Raidex Frontend — copy to .env and fill before building
# These EXPO_PUBLIC_* vars are baked in at build time (EAS or local export).

# Backend API (required)
EXPO_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# Razorpay public key (required when PAYMENT_PROVIDER=razorpay on backend)
# Test: rzp_test_xxx | Live: rzp_live_xxx
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
