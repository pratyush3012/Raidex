{
  "expo": {
    "name": "Raidex",
    "slug": "raidexrentals",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "raidex",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.raidex.app",
      "infoPlist": {
        "UIBackgroundModes": ["location", "remote-notification"]
      }
    },
    "android": {
      "package": "in.raidex.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Raidex needs your location to track active trips.",
          "locationAlwaysPermission": "Raidex uses your location in the background during an active trip.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#05C46B"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Raidex accesses your photos to upload vehicle inspection and KYC images.",
          "cameraPermission": "Raidex uses your camera to capture vehicle and identity photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a0b463b3-c2b7-4b72-87f1-6b3f16287aeb"
      }
    },
    "owner": "wancry30"
  }
}
